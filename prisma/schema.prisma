// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Nouveau modèle unifié pour les programmes de formation
model ProgrammeFormation {
  id                    String    @id @default(uuid())
  code                  String    // Code unique du programme (ex: A001-WP-DD)
  type                  String    // "catalogue" ou "sur-mesure"
  typeProgramme         String?   @map("type_programme") // "standard", "court", "intensif", etc.
  
  // Métadonnées
  version               Int       @default(1) // Numéro de version
  estActif              Boolean   @default(true) @map("est_actif")
  estVisible            Boolean   @default(true) @map("est_visible") // Visible dans le catalogue
  categorieId           String?   @map("categorie_id") // ID de la catégorie
  programmeSourId       String?   @map("programme_source_id") // ID du programme source si dérivé
  pictogramme           String?   // Pictogramme pour le catalogue
  
  // Informations générales
  titre                 String    // Titre du programme
  description           String    // Description courte
  duree                 String    // Durée en heures
  prix                  String    // Prix public
  niveau                String    // Niveau (débutant, intermédiaire, etc.)
  participants          String    // Nombre de participants max/min
  
  // Contenu pédagogique
  objectifs             String[]  // Objectifs pédagogiques sous forme de liste
  objectifsSpecifiques  String?   @map("objectifs_specifiques") // Objectifs spécifiques (sur-mesure)
  prerequis             String    // Prérequis
  publicConcerne        String    @map("public_concerne") // Public concerné
  contenuDetailleJours  String    @map("contenu_detaille_jours") @db.Text // Programme détaillé par jour
  evaluationSur         String?   @map("evaluation_sur") // Critères d'évaluation
  
  // Modalités pratiques
  horaires              String    @default("9h-12h30 et 14h-17h30") // Horaires
  modalites             String    // Modalités pédagogiques (présentiel, distanciel, mixte)
  modalitesAcces        String    @map("modalites_acces") // Modalités d'accès
  modalitesTechniques   String    @map("modalites_techniques") // Modalités techniques
  delaiAcces            String?   @map("delai_acces") // Délai d'accès
  
  // Informations réglementaires
  modalitesReglement    String    @map("modalites_reglement") // Modalités de règlement
  contactOrganisme      String    @default("GestionMax - aurelien@gestionmax.fr - 06.46.02.24.68") @map("contact_organisme") // Contact de l'organisme
  referentPedagogique   String    @default("Aurélien Lien - aurelien@gestionmax.fr") @map("referent_pedagogique") // Référent pédagogique
  referentQualite       String    @default("Aurélien Lien - aurelien@gestionmax.fr") @map("referent_qualite") // Référent qualité
  formateur             String    // Formateur
  ressourcesDisposition String    @map("ressources_disposition") // Ressources mises à disposition
  modalitesEvaluation   String    @map("modalites_evaluation") // Modalités d'évaluation
  sanctionFormation     String    @map("sanction_formation") // Sanction de la formation
  niveauCertification   String    @map("niveau_certification") // Niveau/certification obtenue
  delaiAcceptation      String    @map("delai_acceptation") // Délai d'acceptation
  accessibiliteHandicap String    @map("accessibilite_handicap") // Accessibilité handicap
  cessationAbandon      String    @map("cessation_abandon") // Conditions en cas de cessation/abandon
  
  // Ressources
  programmeUrl          String?   @map("programme_url") // URL du template HTML du programme
  ressourcesAssociees   String[]  @map("ressources_associees") // Liste des ressources associées
  
  // Dates
  dateCreation          DateTime  @default(now()) @map("date_creation")
  dateModification      DateTime  @default(now()) @updatedAt @map("date_modification")

  // Relations
  beneficiaireId        String?   @map("beneficiaire_id") // ID du bénéficiaire si sur-mesure
  formateurId           String?   @map("formateur_id") // ID du formateur assigné
  positionnementRequestId String?  @unique @map("positionnement_request_id") // Lien vers la demande de positionnement
  programmeSource       ProgrammeFormation? @relation("VersionsProgramme", fields: [programmeSourId], references: [id])
  versionsDerivees      ProgrammeFormation[] @relation("VersionsProgramme")
  positionnementRequest PositionnementRequest? @relation(fields: [positionnementRequestId], references: [id])
  dossiers              DossierFormation[]
  categorie             CategorieProgramme? @relation("ProgrammesCategorie", fields: [categorieId], references: [id])
  
  @@map("programmes_formation")
}

// Modèle pour les catégories de programmes
model CategorieProgramme {
  id            String    @id @default(uuid())
  code          String    @unique // Identifiant court (ex: "digital")
  titre         String    // Titre de la catégorie
  description   String    // Description de la catégorie
  ordre         Int       @default(0) // Pour l'ordre d'affichage
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at")
  
  // Relations
  programmes    ProgrammeFormation[] @relation("ProgrammesCategorie")
  
  @@map("categories_programme")
}

// NextAuth.js Models
model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  password      String?   // Pour l'authentification par mot de passe
  nom           String?
  prenom        String?
  role          String    @default("user") // Peut être "user", "admin", "formateur", etc.
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at")
  
  accounts      Account[]
  sessions      Session[]
  reclamationsAssignees Reclamation[] @relation("ReclamationsAssignees")
  
  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Formation {
  id                     String    @id @default(uuid())
  code                   String    // Code de la formation
  libelle                String    // Libellé ou titre de la formation
  
  // Champs légaux et réglementaires (uniquement)
  prerequis              String    // Prérequis
  publicConcerne         String    @map("public_concerne")  // Public concerné
  duree                  String    // Durée
  horaires               String    @default("9h-12h30 et 14h-17h30, adaptables selon les besoins du bénéficiaire") @map("horaires") // Les horaires
  objectifsPedagogiques  String    @map("objectifs_pedagogiques")  // Objectifs pédagogiques
  contenuDetailleJours   String?   @map("contenu_detaille_jours") @db.Text  // Contenu détaillé par jour
  modalitesAcces         String    @default("Formation accessible à distance ou en présentiel selon le contexte") @map("modalites_acces") // Modalités, délais moyens d'accès
  
  tarif                  String    // Tarif de la formation
  modalitesReglement     String    @map("modalites_reglement") // Modalités de règlement
  
  contactOrganisme       String    @default("GestionMax - aurelien@gestionmax.fr - 01.23.45.67.89") @map("contact_organisme") // Contact de l'organisme
  referentPedagogique    String    @default("Aurélien Lien - aurelien@gestionmax.fr") @map("referent_pedagogique") // Référent pédagogique
  referentQualite        String    @default("Aurélien Lien - aurelien@gestionmax.fr") @map("referent_qualite") // Référent qualité
  
  modalitesTechniques    String    @default("Formation en présentiel individuel") // Modalités techniques et pédagogiques
  formateur              String    @default("Formateur spécialisé WordPress avec 5+ ans d'expérience") @map("formateur") // Formateur
  
  ressourcesDisposition  String    @default("Support de cours, tutoriels vidéo, accès à une plateforme d'exercices") @map("ressources_disposition") // L'organisme de formation mettra à disposition de l'apprenant(e)
  modalitesEvaluation    String    @map("modalites_evaluation") // Modalités d'évaluation
  sanctionFormation      String    @map("sanction_formation") // Sanction de la formation
  niveauCertification    String    @default("Formation non certifiante") @map("niveau_certification") // Niveau/certification obtenue
  delaiAcceptation       String    @default("7 jours ouvrables") @map("delai_acceptation") // Délai d'acceptation
  accessibiliteHandicapee String   @default("Formation accessible aux personnes en situation de handicap. Contactez notre référent handicap pour adapter le parcours.") @map("accessibilite_handicapee") // Accessibilité handicapée
  cessationAbandon       String    @map("cessation_abandon") // Cessation anticipée de la formation ou abandon en cours de formation
  
  dateCreation           DateTime  @default(now()) @map("date_creation")
  dateModification       DateTime  @default(now()) @updatedAt @map("date_modification")
  createdAt              DateTime  @default(now()) @map("created_at")

  // Relations
  dossiers               DossierFormation[]
  programmesPersonnalises ProgrammePersonnalise[]
  
  @@map("formations")
}

model Apprenant {
  id        String    @id @default(uuid())
  nom       String
  email     String
  telephone String?
  createdAt DateTime  @default(now()) @map("created_at")
  
  // Relations
  dossiers  DossierFormation[]
  
  @@map("apprenants")
}

model Competence {
  id                   String              @id @default(uuid())
  nom                  String
  description          String
  categorie            String              // 'technique' | 'pedagogique' | 'relationnelle' | 'organisationnelle'
  domaineDeveloppement String              @map("domaine_developpement")
  niveauActuel         Int                 @map("niveau_actuel")
  objectifNiveau       Int                 @map("objectif_niveau")
  statut               String              // 'planifie' | 'en-cours' | 'realise' | 'reporte'
  actionPrevue         String              @map("action_prevue")
  plateformeFomation   String?             @map("plateforme_formation")
  lienFormation        String?             @map("lien_formation")
  typePreuve           String              @map("type_preuve") // 'fichier' | 'url'
  contenuPreuve        String              @map("contenu_preuve")
  dateCreation         DateTime            @default(now()) @map("date_creation")
  dateModification     DateTime            @default(now()) @updatedAt @map("date_modification")
  formateurId          String?             @map("formateur_id")

  @@map("competences")
}

model PositionnementRequest {
  id                      String    @id @default(uuid())
  formationSelectionnee   String?   @map("formation_selectionnee")
  nomBeneficiaire         String    @map("nom_beneficiaire")
  prenomBeneficiaire      String    @map("prenom_beneficiaire")
  emailBeneficiaire       String    @map("email_beneficiaire")
  telephoneBeneficiaire   String?   @map("telephone_beneficiaire")
  niveauBeneficiaire      String?   @map("niveau_beneficiaire")
  objectifs               String[]
  situationActuelle       String    @map("situation_actuelle") // Salarié, indépendant, en création d'entreprise, etc.
  attentes                String
  pratiqueActuelle        String    @map("pratique_actuelle")
  dateDispo               String    @map("date_dispo")
  modaliteFormation       String?   @map("modalite_formation")
  isFinancement           Boolean   @default(false) @map("is_financement") // Besoin de financement externe
  typeFinancement         String?   @map("type_financement") // CPF, OPCO, etc.
  hasHandicap             Boolean   @default(false) @map("has_handicap")
  detailsHandicap         String?   @map("details_handicap")
  besoinHandicap          String?   @map("besoin_handicap")
  entreprise              String?
  siret                   String?   @map("siret")
  adresseEntreprise       String?   @map("adresse_entreprise")
  interlocuteurNom        String?   @map("interlocuteur_nom")
  interlocuteurFonction   String?   @map("interlocuteur_fonction")
  interlocuteurEmail      String?   @map("interlocuteur_email")
  interlocuteurTelephone  String?   @map("interlocuteur_telephone")
  organismeFinanceur      String?   @map("organisme_financeur")
  commentaires            String?
  statut                  String    @default("nouveau") // nouveau, contact_pris, rdv_programme, en_cours, termine, abandonne
  dateContact             DateTime? @map("date_contact") // Date de premier contact
  dateRdv                 DateTime? @map("date_rdv") // Date de rendez-vous
  dateDebutSouhaitee      DateTime? @map("date_debut_souhaitee") // Date de début souhaitée
  dateFinSouhaitee        DateTime? @map("date_fin_souhaitee") // Date de fin souhaitée
  
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @default(now()) @updatedAt @map("updated_at")
  
  // Relations
  dossierFormation        DossierFormation?
  programmePersonnalise   ProgrammePersonnalise?
  programmeFormation      ProgrammeFormation? // Nouvelle relation avec le modèle unifié
  
  @@map("positionnement_requests")
}

model Reclamation {
  id             String    @id @default(uuid())
  nom            String
  email          String
  telephone      String?
  sujet          String
  message        String
  statut         String    @default("nouvelle") // 'nouvelle' | 'en_cours' | 'resolue' | 'fermee'
  priorite       String    @default("normale") // 'basse' | 'normale' | 'haute' | 'urgente'
  assigneeId     String?   @map("assignee_id")
  notesInternes  String?   @map("notes_internes")
  dateResolution DateTime? @map("date_resolution")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at")
  
  // Relations
  assignee       User?     @relation("ReclamationsAssignees", fields: [assigneeId], references: [id])
  actionsCorrectives ActionCorrective[]
  
  @@map("reclamations")
}

model ActionCorrective {
  id                   String    @id @default(uuid())
  titre                String
  description          String
  statut               String    @default("planifiee") // 'planifiee' | 'en_cours' | 'terminee' | 'annulee'
  origineType          String    @map("origine_type") // 'reclamation' | 'incident' | 'audit' | 'veille'
  origineRef           String?   @map("origine_ref")
  origineDate          DateTime? @map("origine_date")
  origineResume        String?   @map("origine_resume")
  priorite             String    @default("moyenne") // 'faible' | 'moyenne' | 'haute' | 'critique'
  avancement           Int       @default(0)
  responsableNom       String?   @map("responsable_nom")
  responsableEmail     String?   @map("responsable_email")
  dateEcheance         DateTime? @map("date_echeance")
  indicateurEfficacite String?   @map("indicateur_efficacite")
  reclamationId        String?   @map("reclamation_id")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @default(now()) @updatedAt @map("updated_at")
  
  // Relations
  reclamation         Reclamation? @relation(fields: [reclamationId], references: [id])
  historiqueActions   HistoriqueActionCorrective[]
  
  @@map("actions_correctives")
}

model HistoriqueActionCorrective {
  id                 String    @id @default(uuid())
  actionCorrectiveId String    @map("action_corrective_id")
  dateAction         DateTime  @default(now()) @map("date_action")
  action             String
  utilisateur        String
  commentaire        String?
  createdAt          DateTime  @default(now()) @map("created_at")
  
  // Relations
  actionCorrective   ActionCorrective @relation(fields: [actionCorrectiveId], references: [id])
  
  @@map("historique_actions_correctives")
}

model PlanAccessibilite {
  id              String    @id @default(uuid())
  titre           String
  description     String
  dateCreation    DateTime  @default(now()) @map("date_creation")
  dateModification DateTime  @default(now()) @updatedAt @map("date_modification")
  actionsRequises String[]  @map("actions_requises")
  statut          String    @default("actif") // 'actif' | 'archive'
  
  @@map("plans_accessibilite")
}

model DemandeAccessibilite {
  id              String    @id @default(uuid())
  nom             String
  email           String
  telephone       String?
  description     String
  dateCreation    DateTime  @default(now()) @map("date_creation")
  statut          String    @default("nouvelle") // 'nouvelle' | 'en_traitement' | 'resolue'
  reponse         String?
  dateResolution  DateTime? @map("date_resolution")
  
  @@map("demandes_accessibilite")
}

model DossierFormation {
  id                     String    @id @default(uuid())
  formationId            String    @map("formation_id")
  apprenantId            String    @map("apprenant_id")
  positionnementId       String?   @unique @map("positionnement_id")
  programmeFormationId   String?   @map("programme_formation_id") // Nouveau champ pour le modèle unifié
  
  statut                 String    @default("inscrit") // inscrit, en_cours, termine, annule
  dateInscription        DateTime  @default(now()) @map("date_inscription")
  dateDebut              DateTime? @map("date_debut")
  dateFin                DateTime? @map("date_fin")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @default(now()) @updatedAt @map("updated_at")
  
  // Relations
  formation              Formation @relation(fields: [formationId], references: [id])
  apprenant              Apprenant @relation(fields: [apprenantId], references: [id])
  positionnement         PositionnementRequest? @relation(fields: [positionnementId], references: [id])
  documents              DocumentFormation[]
  programmeFormation     ProgrammeFormation? @relation(fields: [programmeFormationId], references: [id]) // Nouvelle relation
  
  @@map("dossiers_formation")
}

model DocumentFormation {
  id              String    @id @default(uuid())
  dossierFormationId String  @map("dossier_formation_id")
  nom             String
  type            String
  url             String
  dateCreation    DateTime  @default(now()) @map("date_creation")
  
  // Relations
  dossierFormation DossierFormation @relation(fields: [dossierFormationId], references: [id])
  
  @@map("documents_formation")
}

model ProgrammePersonnalise {
  id                    String    @id @default(uuid())
  formationId           String    @map("formation_id")
  positionnementRequestId String?  @unique @map("positionnement_request_id")
  titre                 String
  description           String
  contenu               String
  duree                 String
  objectifsSpecifiques  String    @map("objectifs_specifiques")
  evaluationSur         String    @map("evaluation_sur")
  
  // Champs légaux et réglementaires
  prerequis             String?   @map("prerequis")
  publicConcerne        String?   @map("public_concerne")
  horaires              String?   @map("horaires")
  modalitesAcces        String?   @map("modalites_acces")
  delaiAcces            String?   @map("delai_acces")
  tarif                 String?   @map("tarif")
  modalitesReglement    String?   @map("modalites_reglement")
  referentPedagogique   String?   @map("referent_pedagogique")
  referentQualite       String?   @map("referent_qualite")
  modalitesTechniques   String?   @map("modalites_techniques")
  formateur            String?   @map("formateur")
  ressourcesDisposition String?   @map("ressources_disposition")
  modalitesEvaluation   String?   @map("modalites_evaluation")
  sanctionFormation     String?   @map("sanction_formation")
  niveauCertification   String?   @map("niveau_certification")
  delaiAcceptation      String?   @map("delai_acceptation")
  accessibiliteHandicap String?   @map("accessibilite_handicap")
  cessationAnticipee    String?   @map("cessation_anticipee")
  
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at")
  
  // Relations
  formation             Formation @relation(fields: [formationId], references: [id])
  positionnementRequest PositionnementRequest? @relation(fields: [positionnementRequestId], references: [id])
  
  @@map("programmes_personnalises")
}

model Veille {
  id            String    @id @default(uuid())
  titre         String
  description   String
  type          String    // 'reglementaire' | 'metier' | 'innovation'
  statut        String    @default("nouvelle") // 'nouvelle' | 'en-cours' | 'terminee'
  avancement    Int       @default(0)
  dateCreation  DateTime  @default(now()) @map("date_creation")
  dateEcheance  DateTime? @map("date_echeance")
  
  @@map("veilles")
}

model ConformiteQualiopi {
  id                 String    @id @default(uuid())
  indicateur         String
  description        String
  statutConformite   String    @map("statut_conformite") // 'conforme' | 'non_conforme' | 'partiellement_conforme'
  dateVerification   DateTime  @map("date_verification")
  prochaineEcheance  DateTime  @map("prochaine_echeance")
  elementPreuve      String?   @map("element_preuve")
  commentaire        String?
  
  @@map("conformite_qualiopi")
}
